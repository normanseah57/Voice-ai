# ==========================================
# Railway Deployment Environment Variables
# ==========================================
# Copy these to your Railway project's Variables tab
# DO NOT commit real values to GitHub

PORT=3000
OPENAI_API_KEY=your_openai_key_here
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret
SIGNALWIRE_PROJECT_ID=your_signalwire_project_id
SIGNALWIRE_API_TOKEN=your_signalwire_api_token
SIGNALWIRE_SPACE_URL=your_signalwire_space_url
JWT_SECRET=your_random_jwt_secret_here
# NGROK_URL is set automatically by Railway in production (do not set this on Railway)
